@using ScarpeCo.Models;  
@using Scarpe_Co.Models;
@model Scarpa

@{
    ViewData["Title"] = "Dettagli Scarpa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>@Model.Nome</h2>
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.Copertina" class="img-fluid" alt="@Model.Nome">
        </div>
        <div class="col-md-6">
            <h4>Prezzo: €@Model.Prezzo</h4>
            <p>@Model.Descrizione</p>
            <div class="mt-3">
                <img src="@Model.Img1" class="img-thumbnail" width="150">
                <img src="@Model.Img2" class="img-thumbnail" width="150">
            </div>
            <a href="@Url.Action("Index", "Scarpe")" class="btn btn-secondary mt-3">Torna Indietro</a>
        </div>
    </div>
</div>
