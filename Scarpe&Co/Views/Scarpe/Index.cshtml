@using ScarpeCo.Models;  // Importa la classe Scarpa

@model List<Scarpa>

@{
    ViewData["Title"] = "Vetrina Scarpe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center">Vetrina Scarpe</h2>
    <div class="row">
        @foreach (var scarpa in Model)
        {
            <div class="col-md-4">
                <div class="card mb-4">
                    <img src="~/images/@scarpa.Copertina" class="card-img-top" alt="@scarpa.Nome">
                    <div class="card-body">
                        <h5 class="card-title">@scarpa.Nome</h5>
                        <p class="card-text">Prezzo: €@scarpa.Prezzo</p>
                        <a href="@Url.Action("Dettaglio", "Scarpe", new { id = scarpa.Id })" class="btn btn-primary">Dettagli</a>
                        <a href="@Url.Action("Modifica", "Scarpe", new { id = scarpa.Id })" class="btn btn-warning">Modifica</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
